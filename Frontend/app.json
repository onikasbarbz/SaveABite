{
  "expo": {
    "name": "SaveABite",
    "slug": "saveabite-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3A7D2C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.luniva.saveabite"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.luniva.saveabite"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "saveabite-app",
    "plugins": [
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ]
  }
}
